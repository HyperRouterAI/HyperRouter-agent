{
  "name": "@hyperrouter/agent",
  "version": "0.1.2",
  "description": "Agent loop framework for Hyper Router — callModel, tools, stop conditions, streaming, observability",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "hyperrouter-agent": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "hyperrouter",
    "agent",
    "llm",
    "ai-agent",
    "tool-calling",
    "streaming"
  ],
  "author": "Hyper Router",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HyperRouterAI/HyperRouter-agent.git"
  },
  "homepage": "https://hyperrouter.ai/docs/agent",
  "bugs": {
    "url": "https://github.com/HyperRouterAI/HyperRouter-agent/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18"
  }
}
